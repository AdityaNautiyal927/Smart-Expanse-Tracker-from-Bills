APP_NAME=Smart Expense Tracker
DEBUG=true
VERSION=1.0.0

DATABASE_URL=sqlite+aiosqlite:///./expenses.db

# PostgreSQL (production) - uncomment to switch
# DATABASE_URL=postgresql+asyncpg://expense_user:expense_pass@localhost:5432/expensedb

# ── OCR Engine ─────────────────────────────────────────────────────────────────
# Options: easyocr | tesseract | stub
# Use "stub" for testing without installing OCR dependencies
OCR_ENGINE=stub
OCR_GPU=false

# ── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Categorization ─────────────────────────────────────────────────────────────
# Options: rule_based | ml_model | hybrid
CATEGORIZATION_ENGINE=rule_based
ML_MODEL_PATH=./models/categorizer.pkl

# ── Async Processing ───────────────────────────────────────────────────────────
# Set to true to use Celery + Redis for heavy OCR workloads
ENABLE_ASYNC_PROCESSING=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Redis (caching) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cloud Storage (optional) ───────────────────────────────────────────────────
USE_S3=false
AWS_BUCKET_NAME=expense-tracker-uploads
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret

# ── CORS ───────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=["https://your-frontend.com","http://localhost:3000"]